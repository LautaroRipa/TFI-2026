Proceso AreaTriangulo
    Definir base, altura, area Como Real
	//se ingresa la base del triangulo
    Escribir "Ingrese la base del tri·ngulo:"
    Leer base
	// se ingresa la altura del triangulo
    Escribir "Ingrese la altura del tri·ngulo:"
    Leer altura
	//se calcula el area del triangulo
    area <- (base * altura) / 2
	//se muestra el area del triangulo
    Escribir "El ·rea del tri·ngulo es: ", area
FinProceso